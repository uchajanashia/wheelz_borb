{
  "name": "@tyre/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm start --workspace @tyre/website",
    "start": "npm start --workspace @tyre/website",
    "build": "npm run build --workspace @tyre/website",
    "build:website": "npm run build --workspace @tyre/website",
    "watch": "npm run watch --workspace @tyre/website",
    "test": "npm test --workspace @tyre/website",
    "lint": "npm run lint --workspace @tyre/website",
    "serve:ssr": "npm run serve:ssr:wheelz --workspace @tyre/website",
    "build:shared": "npm run build --workspace @tyre/shared",
    "dev:start": "node scripts/dev.mjs start",
    "dev:stop": "node scripts/dev.mjs stop",
    "dev:restart": "node scripts/dev.mjs restart",
    "dev:status": "node scripts/dev.mjs status"
  }
}
